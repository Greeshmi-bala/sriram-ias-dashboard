{
  "info": {
    "name": "Anubhuti II Backend API",
    "description": "Complete API collection for testing all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000"
        }
      }
    },
    {
      "name": "Admin - Upload Excel",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "/path/to/your/excel-file.xlsx"
            }
          ]
        },
        "url": {
          "raw": "http://localhost:5000/admin/upload",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["admin", "upload"]
        }
      }
    },
    {
      "name": "Admin - Search Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/admin/search?query=rahul",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["admin", "search"],
          "query": [
            {
              "key": "query",
              "value": "rahul"
            }
          ]
        }
      }
    },
    {
      "name": "Auth - Request OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"phone\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Auth - Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"otp\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/auth/verify-otp",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["auth", "verify-otp"]
        }
      }
    },
    {
      "name": "Admit Card - Download PDF",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/admit/download?email=rahul@example.com",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["admit", "download"],
          "query": [
            {
              "key": "email",
              "value": "rahul@example.com"
            }
          ]
        }
      }
    }
  ]
}
